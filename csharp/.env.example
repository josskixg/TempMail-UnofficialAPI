# TempMail Wrapper — Environment Variables
# Copy this file to .env and fill in your values

# Resend API key for E2E test email delivery
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Optional: HTTP/HTTPS Proxy URL for proxying requests (supported by underlying HTTP libraries)
# HTTP_PROXY=http://your_proxy_server:port
# HTTPS_PROXY=http://your_proxy_server:port
# NO_PROXY=localhost,127.0.0.1
